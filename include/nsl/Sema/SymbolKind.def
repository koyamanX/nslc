// SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
//
// SymbolKind.def — single source of truth for the closed set of
// concrete `Symbol` kinds in `nsl-sema` (data-model §1.5; mirrors
// `docs/design/nsl_compiler_design.md` §6 lines 692–759).
//
// Format:
//   NSL_SYMBOL_KIND(EnumName, ConcreteClass)
// where:
//   - `EnumName` is the suffix of the `SymbolKind` enumerator
//     (the enumerator itself is `SK_<EnumName>`).
//   - `ConcreteClass` is the concrete C++ class name nested inside
//     `include/nsl/Sema/SymbolTable.h` (per Constitution Principle
//     II §3 amended at v1.6.0: Symbol subclasses nest in
//     `SymbolTable.h`, NOT as separate per-kind headers).
//
// Adding a kind: insert one `NSL_SYMBOL_KIND(...)` line in the
// matching group below. The X-macro pattern propagates the change
// to the `SymbolKind` enum body in `SymbolTable.h`, the
// kind-to-string table in `lib/Sema/SymbolTable.cpp`, and any
// future code-generated visitors that include this file. No other
// edits needed (research §2 single-source).
//
// Determinism: source order of these entries is the iteration
// order of the kind-to-string table. Two builds produce identical
// artifacts iff this file is unchanged byte-for-byte (Principle V;
// FR-030).

// ---- Value symbols (data-model §1.2; design §6 lines 700–714) ----
NSL_SYMBOL_KIND(Port,         PortSymbol)
NSL_SYMBOL_KIND(Reg,          RegSymbol)
NSL_SYMBOL_KIND(Wire,         WireSymbol)
NSL_SYMBOL_KIND(Variable,     VariableSymbol)
NSL_SYMBOL_KIND(Integer,      IntegerSymbol)
NSL_SYMBOL_KIND(Mem,          MemSymbol)

// ---- Control symbols (data-model §1.3; design §6 lines 716–730) ----
NSL_SYMBOL_KIND(FuncIn,       FuncInSymbol)
NSL_SYMBOL_KIND(FuncOut,      FuncOutSymbol)
NSL_SYMBOL_KIND(FuncSelf,     FuncSelfSymbol)

// ---- Procedure / state / submodule / struct (data-model §1.4) ----
NSL_SYMBOL_KIND(Proc,         ProcSymbol)
NSL_SYMBOL_KIND(State,        StateSymbol)
NSL_SYMBOL_KIND(Submodule,    SubmoduleSymbol)
NSL_SYMBOL_KIND(StructType,   StructTypeSymbol)
