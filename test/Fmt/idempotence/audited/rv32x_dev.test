//
// T109 — audited-corpus idempotence sweep for rv32x_dev (per
// SC-002 + FR-021 + `research.md` §6). Asserts every `*.nsl`
// file under `test/audited/rv32x_dev/` reaches a fixed point
// under `nsl-fmt | nsl-fmt`.
//
// Activates automatically when M7's P-VEN vendoring lands
// `test/audited/rv32x_dev/`; today the require-feature line skips
// this fixture via `test/lit.cfg.py`'s `audited-rv32x_dev`
// feature probe.

// REQUIRES: audited-rv32x_dev

// RUN: for f in %S/../../../audited/rv32x_dev/*.nsl; do \
// RUN:   nsl-fmt --stdin < $f > %t.once && \
// RUN:   nsl-fmt --stdin < %t.once > %t.twice && \
// RUN:   cmp %t.once %t.twice; \
// RUN: done
