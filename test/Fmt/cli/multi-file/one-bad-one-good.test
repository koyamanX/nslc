//
// T068: `nsl-fmt <bad> <good>` continues past the parse error on
// `bad.nsl` and processes `good.nsl` (FR-003a continue-on-error).
// The aggregate exit is 1, the good file's formatted text lands on
// stdout, and only the bad file's diagnostic appears on stderr.
// Coverage backfill for the multi-file loop in
// `tools/nsl-fmt/main.cpp` (lines 334–381 — `aggregateExit |= rc`).

// RUN: printf 'declare a { } module a { wire x[8]; }\n' > %t.good.nsl
// RUN: printf 'this is not nsl &^@\n' > %t.bad.nsl
// RUN: not nsl-fmt %t.bad.nsl %t.good.nsl 2> %t.stderr | FileCheck %s --check-prefix=STDOUT
// RUN: FileCheck %s --check-prefix=STDERR --input-file=%t.stderr

// STDOUT: declare a { } module a { wire x[8]; }

// STDERR-NOT: good.nsl
// STDERR: bad.nsl: error: expected top-level item
// STDERR-NOT: good.nsl
