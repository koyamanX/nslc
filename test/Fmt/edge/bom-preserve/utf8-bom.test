//
// T041: a UTF-8 BOM (EF BB BF) at the start of the input is
// preserved byte-for-byte on output. Phase 2c's DirectiveSplitter
// retains BOM bytes in the leading slice's `rawText`; format_buffer
// concatenates slice rawText verbatim — round-trip identity.

// RUN: printf '\xef\xbb\xbfmodule foo {}\n' > %t.in
// RUN: nsl-fmt --stdin < %t.in > %t.out
// RUN: cmp %t.in %t.out
