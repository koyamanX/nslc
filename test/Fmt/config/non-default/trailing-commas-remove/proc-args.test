// SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
//
// T122 (b/b) — non-default config: `trailing_commas = "remove"`
// strips any pre-existing trailing comma from the last arg in a
// multi-line `proc_name` argument list (per `formatting-rules.
// contract.md` §3 trailing-comma policy + §9 rule↔key matrix
// row R3 ↔ `trailing_commas`).
//
// Default config is `trailing_commas = "preserve"`; this fixture
// flips to `"remove"` and verifies that an explicit trailing
// comma in the source is dropped from the output.
//
// AUTHORED RED — XFAIL until T054 implements R3 (`proc_name`
// argument-list wrapping) AND the trailing-comma policy is wired
// in `formatNode(ProcNameDecl)`.

// XFAIL: *

// RUN: rm -rf %t.tc && mkdir -p %t.tc
// RUN: printf 'trailing_commas = "remove"\n' > %t.tc/.nsl-fmt.toml
// RUN: printf 'module m {\n  proc_name exec(\n    pc[32],\n    inst[32],\n    src1[32],\n    src2[32],\n  );\n}\n' > %t.tc/m.nsl
// RUN: cd %t.tc && nsl-fmt m.nsl | FileCheck %s

// CHECK:     pc   [32],
// CHECK-NEXT:     inst [32],
// CHECK-NEXT:     src1 [32],
// CHECK-NEXT:     src2 [32]
// CHECK-NOT:  src2 [32],
// CHECK-NEXT: );
