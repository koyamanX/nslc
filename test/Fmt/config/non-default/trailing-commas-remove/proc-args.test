// SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
//
// T122 (b/b) — non-default config: `trailing_commas = "remove"`
// guarantees no trailing comma after the last arg in a
// multi-line `proc_name` argument list (per
// `formatting-rules.contract.md` §3 trailing-comma policy +
// §9 rule↔key matrix row R3 ↔ `trailing_commas`; §3 amended
// Session 2026-05-12 — see `plan.md` Plan Revisions).
//
// **Scope note**: the NSL parser at `lib/Parse/ParseDecl.cpp:893
// –923` does not accept a literal trailing comma in the
// `proc_name (..., ,)` source form (it errors with `expected
// identifier after ','`), so the "remove" mode is exercised
// here against a clean input — the assertion is that the
// formatter MUST NOT introduce a trailing comma in the
// multi-line output even though config is `"remove"`. The
// invariant is the SAME as the default `"preserve"` mode for
// this construct; this fixture wires the config-honoured path
// end-to-end for regression coverage. A future `proc_name`
// grammar extension that adds trailing-comma tolerance would
// motivate a real before/after test.
//
// T054 (this commit) implements R3 — fixture flipped
// XFAIL→PASS.

// RUN: rm -rf %t.tc && mkdir -p %t.tc
// RUN: printf 'trailing_commas = "remove"\n' > %t.tc/.nsl-fmt.toml
// RUN: printf 'module m { reg argument_one[8]; reg argument_two[8]; reg argument_three[8]; reg argument_four[8]; reg argument_five[8]; reg argument_six[8]; reg argument_seven[8]; proc_name long_arg_proc(argument_one, argument_two, argument_three, argument_four, argument_five, argument_six, argument_seven); }\n' > %t.tc/m.nsl
// RUN: cd %t.tc && nsl-fmt m.nsl | FileCheck %s

// CHECK-LABEL: proc_name long_arg_proc(
// CHECK:      argument_one,
// CHECK-NEXT: argument_two,
// CHECK-NEXT: argument_three,
// CHECK-NEXT: argument_four,
// CHECK-NEXT: argument_five,
// CHECK-NEXT: argument_six,
// CHECK-NEXT: argument_seven
// CHECK-NEXT: );
