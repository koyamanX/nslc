//
// T101: `indent = "potato"` (known key, unknown enum value)
// aborts with exit 2 + the frozen "must be" diagnostic on stderr
// (FR-016 — silently using a default would hide the user's
// mistake).

// RUN: printf 'indent = "potato"\n' > %t.toml
// RUN: printf 'module foo {}\n' > %t.nsl
// RUN: not nsl-fmt --config %t.toml %t.nsl 2>&1 | FileCheck %s
// CHECK: error: configuration value for 'indent' must be
