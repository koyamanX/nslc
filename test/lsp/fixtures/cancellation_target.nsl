// SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
//
// test/lsp/fixtures/cancellation_target.nsl - large fixture used by
// FoldingSuite::Cancellation_Under200ms (T093, SC-010). Hand-
// generated repetition of a multi-line module-with-funcs pattern
// produces well over 10,000 AST nodes that the M2 parser exposes
// for FoldingRangeBuilder to walk. Each module emits multi-line
// blocks (fold-eligible per folding-range.contract.md sec.2);
// the per-node cancellation poll (sec.5) gets ample opportunity
// to observe the cancel signal and abort within the 200 ms
// budget.
//
// Sized so the builder traverses long enough to make cancellation
// observable but not so long that an uncancelled run blows the
// gtest-discover timeout. Adjust N below if the timing budget
// needs revisiting.

module mod_0000 {
  reg r0_0000;
  reg r1_0000;
  reg r2_0000;
  reg r3_0000;
  reg r4_0000;
  reg r5_0000;
  reg r6_0000;
  reg r7_0000;
  wire w0_0000;
  wire w1_0000;
  wire w2_0000;
  wire w3_0000;
  func_self f_0000;
  func f_0000 {
    seq {
      r0_0000 = r1_0000;
      r1_0000 = r2_0000;
      r2_0000 = r3_0000;
      r3_0000 = r4_0000;
      r4_0000 = r5_0000;
      r5_0000 = r6_0000;
    }
  }
}

