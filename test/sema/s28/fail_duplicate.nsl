// RUN: not %nslc -emit=ast %s 2>&1 | FileCheck %s

module m_fail {
  proc_name p;
  proc p {
    state_name s1, s2;
    first_state s1;
    first_state s2;
    state s1 { }
    state s2 { }
  }
}

