// RUN: not %nslc -emit=ast %s 2>&1 | FileCheck %s

module m_fail {
  proc_name p;
  proc p {
    state_name s1;
    first_state ghost;
    state s1 { }
  }
}

// CHECK: error: 'first_state' must reference a 'state_name' declared in the enclosing 'proc' (S28)
