//
// test/sema/width/concat_expr.test — concat-expression width fixture
// (T024 rollover; specs/006-m3-sema/tasks.md Phase 4a). Asserts the
// `ConcatExpr` for `{a, b}` carries a `: BitVector(N)` Type suffix
// per `emit-ast-format.contract.md` Invariant 2 — the result width
// is the sum of operand widths.

// RUN: printf 'module m {\n  wire a;\n  wire b;\n  reg q = {a, b};\n}\n' > %t.nsl
// RUN: %nslc -emit=ast %t.nsl | FileCheck %s

// CHECK: (RegDecl {{.*}}name=q
// CHECK: (ConcatExpr {{.*}} : BitVector({{[0-9]+}})
