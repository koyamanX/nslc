// SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
//
// test/Driver/emit_verilog/multi_module_stdout.test — M7 US1 fixture
// (T021). Asserts `-o` omitted (or `-o -`) emits a single combined
// Verilog file to stdout containing both modules in stable order.
//
// Per `driver-emit-verilog.contract.md` §1 dispatch path (c).

// RUN: %nslc -emit=verilog %S/fixtures/multi_module.nsl | %FileCheck %s
// RUN: %nslc -emit=verilog %S/fixtures/multi_module.nsl -o - | %FileCheck %s

// Both modules appear in the same output stream.
// CHECK-DAG: module ModA
// CHECK-DAG: module ModB

// No `nsl.` / `fsm.` / `seq.` residue.
// CHECK-NOT: nsl.
// CHECK-NOT: fsm.
// CHECK-NOT: seq.
