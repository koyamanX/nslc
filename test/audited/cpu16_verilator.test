// REQUIRES: verilator

// RUN: rm -rf %t-verilog && mkdir -p %t-verilog
// RUN: %nslc -emit=verilog %S/cpu16/cpu.nsl -o %t-verilog/

// Verilator build + simulate. The `--binary` mode produces a
// standalone simulation binary that dumps VCD when run.
// RUN: verilator --binary --build --top-module cpu \
// RUN:   -Mdir %t-verilator -o %t.verilator \
// RUN:   %t-verilog/*.v %S/cpu16/cpu_sim.nsl

// Run + capture VCD.
// RUN: cd %T && %t-verilator/%t.verilator +trace +VCDFILE=%t.vcd

// Compare against golden.
// RUN: %vcd-diff %S/cpu16/golden/cpu16_basic.vcd %t.vcd
