//
// T016 fixture — @variable.register / @variable.wire / @variable.memory
// captures at both declaration and reference sites.
//
// Cross-references:
//   - spec FR-007 (sub-captures) and Clarifications session 2026-05-05 Q3 → Option B
//   - contracts/highlights-coverage.contract.md §3 row 1
//   - data-model.md §1.1 (parse-tree node bindings)
//   - acceptance scenarios AS1.1 + AS1.2
//
// Assertion format (upstream `tree-sitter test`):
//   // <- capture        — column 0 of the line above
//   //   ^ capture       — the column the `^` aligns with on the line above
//
// Six minimum assertions per highlights-coverage §3 row 1 (decl + ref
// for each of register/wire/memory).

declare reg_wire_mem {
    input  d[8];
    output q_out[8];
}

module reg_wire_mem {
    reg q[8] = 0;
//      ^ variable.register
    wire w[8];
//       ^ variable.wire
    mem m[16][8];
//      ^ variable.memory

    q := d;
//  ^ variable.register
    w = q;
//  ^ variable.wire
//      ^ variable.register
    q_out = m[0];
//          ^ variable.memory
}
