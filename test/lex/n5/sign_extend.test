// SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
//
// test/lex/n5/sign_extend.test — N5 disambiguation per `lang.ebnf`
// lines 1035–1049. A `#` in expression position (NOT at start-of-
// line) classifies as `tk_hash_sign_extend` — the n#sig sign-
// extension operator. The lexer reaches the `#` after consuming
// other tokens on the same logical line, so `at_line_start_` is
// false; the disambiguation falls through to the operator case.
//
// The minimal fixture: a single statement `x = a#b;` where the `#`
// is unambiguously the sign-extend operator (it's not at column 1).

// RUN: %nslc -emit=tokens %s | FileCheck %s

x = a#b;
// CHECK:      tk_identifier	x	{{[^:]+}}:1:1:0	{{[^:]+}}:1:1	[]
// CHECK-NEXT: tk_assign	=	{{[^:]+}}:1:3:2	{{[^:]+}}:1:3	[]
// CHECK-NEXT: tk_identifier	a	{{[^:]+}}:1:5:4	{{[^:]+}}:1:5	[]
// CHECK-NEXT: tk_hash_sign_extend	#	{{[^:]+}}:1:6:5	{{[^:]+}}:1:6	[]
// CHECK-NEXT: tk_identifier	b	{{[^:]+}}:1:7:6	{{[^:]+}}:1:7	[]
// CHECK-NEXT: tk_semicolon	;	{{[^:]+}}:1:8:7	{{[^:]+}}:1:8	[]
// CHECK-NEXT: tk_eof
