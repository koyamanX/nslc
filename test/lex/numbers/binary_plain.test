//
// test/lex/numbers/binary_plain.test — C-style binary literal per
// `lang.ebnf §13` `c_style_number` with `c_radix_char = "b"`.

// RUN: echo '0b101' > %t.nsl
// RUN: %nslc -emit=tokens %t.nsl | FileCheck %s

// CHECK:      tk_binary_lit	0b101	{{[^:]+}}:1:1:0	{{[^:]+}}:1:1	[]
// CHECK-NEXT: tk_eof
