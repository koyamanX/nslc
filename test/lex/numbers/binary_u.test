//
// test/lex/numbers/binary_u.test — C-style binary literal with `U`
// digit per `lang.ebnf §13`.

// RUN: echo '0b1U' > %t.nsl
// RUN: %nslc -emit=tokens %t.nsl | FileCheck %s

// CHECK:      tk_binary_lit	0b1U	{{[^:]+}}:1:1:0	{{[^:]+}}:1:1	[U]
// CHECK-NEXT: tk_eof
