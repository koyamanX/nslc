//
// test/lex/numbers/hex_u.test — C-style hex literal with `U` digit
// (Undriven marker) per `lang.ebnf §13`.

// RUN: echo '0xfU' > %t.nsl
// RUN: %nslc -emit=tokens %t.nsl | FileCheck %s

// CHECK:      tk_hex_lit	0xfU	{{[^:]+}}:1:1:0	{{[^:]+}}:1:1	[U]
// CHECK-NEXT: tk_eof
