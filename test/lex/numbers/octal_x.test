//
// test/lex/numbers/octal_x.test — Verilog-style octal literal with
// `X` digit per `lang.ebnf §13`.

// RUN: %nslc -emit=tokens %s | FileCheck %s

8'oX
// CHECK:      tk_octal_lit	8'oX	{{[^:]+}}:1:1:0	{{[^:]+}}:1:1	[X]
// CHECK-NEXT: tk_eof
