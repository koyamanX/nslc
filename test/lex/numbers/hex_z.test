// SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
//
// test/lex/numbers/hex_z.test — C-style hex literal with `Z` digit
// (Hi-Z marker) per `lang.ebnf §13` value_digit. The `[Z]` flag in
// the token's flags column reflects the digit class; case is
// normalized to upper-Z in the flags rendering.

// RUN: %nslc -emit=tokens %s | FileCheck %s

0xfZ
// CHECK:      tk_hex_lit	0xfZ	{{[^:]+}}:1:1:0	{{[^:]+}}:1:1	[Z]
// CHECK-NEXT: tk_eof
