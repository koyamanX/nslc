//
// test/lex/numbers/verilog_binary_x.test — Verilog-style binary
// literal with all-`X` value-run per `lang.ebnf §13`.

// RUN: echo '4'\''bXXXX' > %t.nsl
// RUN: %nslc -emit=tokens %t.nsl | FileCheck %s

// CHECK:      tk_binary_lit	4'bXXXX	{{[^:]+}}:1:1:0	{{[^:]+}}:1:1	[X]
// CHECK-NEXT: tk_eof
