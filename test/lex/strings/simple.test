// SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
//
// test/lex/strings/simple.test — minimal string literal per
// `lang.ebnf §13` `string_literal = '"' { string_char } '"'`. The
// token's spelling preserves the surrounding double quotes; that's
// the literal source span per data-model entity 8 invariant
// (`range_.length() == spelling_.size()`).

// RUN: echo '"hello"' > %t.nsl
// RUN: %nslc -emit=tokens %t.nsl | FileCheck %s

// CHECK:      tk_string_lit	\"hello\"	{{[^:]+}}:1:1:0	{{[^:]+}}:1:1	[]
// CHECK-NEXT: tk_eof
