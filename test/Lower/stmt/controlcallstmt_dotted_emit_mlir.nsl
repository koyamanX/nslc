// test/Lower/stmt/controlcallstmt_dotted_emit_mlir.nsl ‚Äî US1 fixture
// covering `ast::ControlCallStmt` with a multi-part `ScopedName`
// (per parser-note N6 ‚Äî proc-instance method access form
// `inst.method`). Per Q5 Option A' the dotted form lowers to a
// literal-dotted `FlatSymbolRefAttr` ‚Äî i.e., `@inst.method` ‚Äî with
// no special name mangling. Mirrors the dotted-call line in
// `test/Dialect/atomic/call_roundtrip.mlir`.

// RUN: %nslc -emit=mlir %s | %FileCheck %s

module M {
  {
    inst.start();
  }
}

// CHECK: nsl.module @M
// CHECK: nsl.parallel
// CHECK-NEXT: nsl.call @inst.start() : () -> ()
