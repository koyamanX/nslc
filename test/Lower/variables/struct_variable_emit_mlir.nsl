//
// test/Lower/variables/struct_variable_emit_mlir.nsl —
// **ASPIRATIONAL FIXTURE.** Marked expected-to-fail (see directive
// at the bottom of the file) until/unless NSL the *language* is
// extended.
//
// This fixture is NOT a deferred implementation — the source pattern
// it exercises is **not part of the NSL grammar**:
//
//   struct T { a[8]; b[8]; };
//   module M {
//     T variable s;        // <-- NOT in lang.ebnf
//     s.a = 0;
//     s.b = 0;
//   }
//
// Per `lang.ebnf §6` lines 311–314:
//
//   variable_declaration = "variable" variable_declarator
//                          { "," variable_declarator } ";" ;
//   variable_declarator  = identifier [ "[" width_expression "]" ] ;
//
// `variable` is strictly bare-form (`variable name;` or
// `variable name[width];`). The struct-instance form
// `<Type> reg s;` / `<Type> wire s;` (lang.ebnf line 297
// `struct_instance_declaration`) is deliberately NOT extended to
// `variable`. NSL does not currently have struct-typed variables.
//
// Closing this fixture would require, in order:
//
//   (a) An NSL **language** amendment extending
//       `variable_declaration` to admit a TypeRef prefix (a spec
//       PR — Constitution Principle I + VII, with audited-corpus
//       review since none of the seven audited projects use
//       struct-typed variables today).
//   (b) M2 parser path for the new form.
//   (c) Either an M4 amendment relaxing `nsl.variable`'s
//       `NSL_AnyBits` result constraint to admit `!nsl.struct<@T>`,
//       OR — preferred — an AST-time per-field decomposition that
//       lowers `T variable s;` into per-field `nsl.variable` ops.
//   (d) `NSLExpandVariablesPass` per-field handling (clone the
//       chain per field; merge on whole-struct read sites).
//   (e) An MLIR struct-pack op (or composition via `nsl.field` +
//       `nsl.concat` + `nsl.struct_cast`) so whole-struct reads
//       compose cleanly.
//
// All five preconditions are out of scope for an infra-cleanup PR.
// The CHECK lines below preserve the intended post-amendment IR
// shape so a future spec/implementation PR has a target to satisfy.
//
// XFAIL: *
// RUN: %nslc -emit=mlir %s | %FileCheck %s

struct T {
  a[8];
  b[8];
};

module M {
  T variable s;     // CHECK: nsl.variable
  s.a = 0;
  s.b = 0;
}

// CHECK-NOT: nsl.variable
