// SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
//
// test/Lower/action/altblock_emit_mlir.nsl — US1 fixture covering
// `ast::AltBlock`. Per FR-006 lowering table row "AltBlock →
// nsl.alt { nsl.case ... nsl.default ... }" (design §7 line 903).
// Per S13 alt is constructive (priority-encoded vs parallel) — the
// dialect verifier does NOT distinguish alt-vs-any; that's an
// introspection observable in M3.
//
// Container shape: top-level `par-block` (matches the existing
// `ifstmt_emit_mlir.nsl` shape — `nsl.alt` carries no `HasParent`,
// matching the M4 round-trip fixture
// `test/Dialect/action-block/alt_roundtrip.mlir` lifted into a func+seq
// for that fixture but legal at par-scope here).

// RUN: %nslc -emit=mlir %s | %FileCheck %s

module M {
  wire c1[1];
  wire c2[1];
  wire a[8];
  wire b[8];
  {
    alt {
      c1: a = b;
      c2: a = b;
      else: a = b;
    }
  }
}

// CHECK: nsl.module @M
// CHECK: nsl.parallel
// CHECK: nsl.alt
// CHECK: nsl.case %{{.*}} : !nsl.bits<1>
// CHECK: nsl.transfer %{{.*}}, %{{.*}} : !nsl.bits<8>
// CHECK: nsl.case %{{.*}} : !nsl.bits<1>
// CHECK: nsl.transfer %{{.*}}, %{{.*}} : !nsl.bits<8>
// CHECK: nsl.default
// CHECK: nsl.transfer %{{.*}}, %{{.*}} : !nsl.bits<8>
