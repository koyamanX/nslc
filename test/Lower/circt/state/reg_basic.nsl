// SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
//
// test/Lower/circt/state/reg_basic.nsl — M6 Phase 6 fixture (T080).
// Per `firreg-convention.contract.md` §5: bare `reg r[8] = 0; r := a;
// q = r;` produces `seq.firreg` with async-active-HIGH reset wired
// directly to the auto-synthesized `p_reset` port. Round-1 review
// correction (PR #14): the auto-synth ports are `m_clock` (clock)
// and `p_reset` (active-HIGH reset, per the `p_` prefix convention
// in nsl_lang.ebnf §15 lines 818, 820); the previous active-LOW
// `rst_n` adapter (`comb.icmp eq %rst_n, 0`) has been removed.

// RUN: %nslc -emit=hw %s | %FileCheck %s

declare M {
  input a[8];
  output q[8];
}

module M {
  reg r[8] = 0;
  r := a;
  q = r;
}

// CHECK-LABEL: hw.module @M
// CHECK-SAME: in %a : i8
// CHECK-SAME: in %m_clock : i1
// CHECK-SAME: in %p_reset : i1
// CHECK-SAME: out q : i8
// CHECK: seq.to_clock %m_clock
// CHECK: seq.firreg
// CHECK-SAME: reset async
// CHECK: hw.output
// CHECK-NOT: comb.icmp eq %p_reset
// CHECK-NOT: nsl.
