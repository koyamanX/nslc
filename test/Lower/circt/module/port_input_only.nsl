// SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
//
// test/Lower/circt/module/port_input_only.nsl — M6 Phase 4 (US2)
// fixture (T030). Asserts that an `input`-only declare block lowers
// to `hw.module @M(%a: i8, %clk: i1, %rst_n: i1)` per
// `circt-lowering.contract.md` §3 rule 6 (implicit clk + rst_n
// appended at end of input port list when no `interface` modifier
// is present).

// RUN: %nslc -emit=hw %s | %FileCheck %s

declare M {
  input a[8];
}

module M {
}

// CHECK-LABEL: hw.module @M
// CHECK-SAME: in %a : i8
// CHECK-SAME: in %clk : i1
// CHECK-SAME: in %rst_n : i1
// CHECK-NOT: nsl.
