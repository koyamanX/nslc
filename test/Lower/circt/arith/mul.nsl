// test/Lower/circt/arith/mul.nsl — M6 Phase 6 fixture (T063).
// `nsl.mul` → `comb.mul`.

// RUN: %nslc -emit=hw %s | %FileCheck %s

declare M {
  input a[8];
  input b[8];
  output q[8];
}

module M {
  q = a * b;
}

// CHECK-LABEL: hw.module @M
// CHECK: comb.mul %a, %b : i8
// CHECK-NOT: nsl.
