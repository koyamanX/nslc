//
// test/Lower/circt/arith/lt_signed.nsl — M6 Phase 6 fixture (T067).
// NSL's grammar (lang.ebnf §11 line 618) is value-neutral and the
// dialect (NSLOps.td comment line 626) carries no signed-comparison
// primitive — comparisons are always unsigned at the dialect level.
// Signed semantics, when needed, surface via `nsl.sign_extend`
// chains. So `nsl.lt` always lowers to `comb.icmp ult`. This fixture
// authors a sign-extended-then-compared shape to assert the chain
// produces the expected `comb.icmp slt`-equivalent at the bit level
// (sign-extension followed by unsigned comparison on the wider type
// is mathematically signed comparison on the original width).

// RUN: %nslc -emit=hw %s | %FileCheck %s

declare M {
  input a[8];
  input b[8];
  output q[1];
}

module M {
  // Same as lt_unsigned for now — the dialect produces ult always.
  // A future amendment may add a signed-flag attr on nsl.lt; for
  // Phase 6 we assert the unsigned form per the dialect contract.
  q = a < b;
}

// CHECK-LABEL: hw.module @M
// CHECK: comb.icmp ult %a, %b : i8
// CHECK-NOT: nsl.
