//
// test/Lower/circt/arith/eq.nsl — M6 Phase 6 fixture (T064).
// `nsl.eq` → `comb.icmp eq`.

// RUN: %nslc -emit=hw %s | %FileCheck %s

declare M {
  input a[8];
  input b[8];
  output q[1];
}

module M {
  q = a == b;
}

// CHECK-LABEL: hw.module @M
// CHECK: comb.icmp eq %a, %b : i8
// CHECK-NOT: nsl.
