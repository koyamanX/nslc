//
// test/Lower/circt/arith/lt_unsigned.nsl — M6 Phase 6 fixture (T066).
// `nsl.lt` → `comb.icmp ult` (NSL semantics are unsigned per dialect
// docs and circt-lowering.contract.md §1).

// RUN: %nslc -emit=hw %s | %FileCheck %s

declare M {
  input a[8];
  input b[8];
  output q[1];
}

module M {
  q = a < b;
}

// CHECK-LABEL: hw.module @M
// CHECK: comb.icmp ult %a, %b : i8
// CHECK-NOT: nsl.
