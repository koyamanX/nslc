//
// test/Lower/circt/arith/ge.nsl — M6 Phase 6 fixture (T070).
// `nsl.ge` → `comb.icmp uge` (unsigned).

// RUN: %nslc -emit=hw %s | %FileCheck %s

declare M {
  input a[8];
  input b[8];
  output q[1];
}

module M {
  q = a >= b;
}

// CHECK-LABEL: hw.module @M
// CHECK: comb.icmp uge %a, %b : i8
// CHECK-NOT: nsl.
