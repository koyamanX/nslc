//
// test/Lower/circt/arith/shift.nsl — M6 Phase 6 fixture (T072).
// `nsl.shl` → `comb.shl`; `nsl.shr` → `comb.shru` (logical right
// shift; NSL's grammar §11 line 620 lists only `<<` and `>>`).

// RUN: %nslc -emit=hw %s | %FileCheck %s

declare M {
  input a[8];
  input b[8];
  output qs[8];
  output qr[8];
}

module M {
  qs = a << b;
  qr = a >> b;
}

// CHECK-LABEL: hw.module @M
// CHECK-DAG: comb.shl %a, %b : i8
// CHECK-DAG: comb.shru %a, %b : i8
// CHECK-NOT: nsl.
