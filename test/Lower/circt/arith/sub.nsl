// test/Lower/circt/arith/sub.nsl — M6 Phase 6 fixture (T062).
// `nsl.sub` → `comb.sub`.

// RUN: %nslc -emit=hw %s | %FileCheck %s

declare M {
  input a[8];
  input b[8];
  output q[8];
}

module M {
  q = a - b;
}

// CHECK-LABEL: hw.module @M
// CHECK: comb.sub %a, %b : i8
// CHECK-NOT: nsl.
