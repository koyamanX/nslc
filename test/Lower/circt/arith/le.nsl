//
// test/Lower/circt/arith/le.nsl — M6 Phase 6 fixture (T068).
// `nsl.le` → `comb.icmp ule` (unsigned per dialect).

// RUN: %nslc -emit=hw %s | %FileCheck %s

declare M {
  input a[8];
  input b[8];
  output q[1];
}

module M {
  q = a <= b;
}

// CHECK-LABEL: hw.module @M
// CHECK: comb.icmp ule %a, %b : i8
// CHECK-NOT: nsl.
