// SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
//
// test/Lower/circt/round_trip/loc_plumbing.nsl — M6 US1 harness
// fixture (T027). Asserts FR-005 + FR-030 + SC-004: every CIRCT
// op produced by the M6 conversion carries an `mlir::Location`
// resolvable to the originating `.nsl` source position. NO
// `loc(unknown)` is permitted in the output.
//
// **Phase 4 status: PASS** (XFAIL removed in the same commit that
// landed T038). The structural rewrite preserves every op's
// `mlir::Location` from the originating `nsl::*` op (or the paired
// declare-body op for ports); `mlir::UnknownLoc` is never introduced.
//
// Constitutional anchor: Principle IV (Source-Locating Diagnostics).
//
// **Implementation note (PR #14 review #6 fix)**: `nslc -emit=hw` uses
// MLIR's default printer with default OpPrintingFlags (per
// `driver-emit-hw.contract.md` section 4 — the printer-flag freeze),
// which SUPPRESSES `loc(...)` annotations. A naive
// `%nslc -emit=hw %s | %FileCheck %s` pipeline would print no
// `loc(...)` whatsoever and a "no-unknown-loc" assertion would
// trivially pass even if every op carried `UnknownLoc`. To actually
// assert no UnknownLoc, the output is round-tripped through
// `nsl-opt --mlir-print-debuginfo` which re-prints WITH explicit
// location annotations; the FileCheck then has real `loc(...)` text
// to match against. Both a positive (must-appear) and a negative
// (must-not-appear) directive are exercised: at least one
// `loc(...)` MUST appear (proving the printer ran with debug info
// on); zero of those may be `loc(unknown)`.

// RUN: %nslc -emit=hw %s | nsl-opt --mlir-print-debuginfo - | %FileCheck %s

declare M {
  input a[8];
  output q[8];
}

module M {
  q = a;
}

// CHECK-LABEL: hw.module @M
// CHECK: loc(
// CHECK-NOT: loc(unknown)
