//
// test/Lower/circt/control/chained_if_reg.nsl — M6 Phase 6 fixture
// (T090). Chained `if`-over-reg lowers to nested `comb.mux` chain;
// ONE `seq.firreg` regardless of depth (Q3 → A).

// RUN: %nslc -emit=hw %s | %FileCheck %s

declare M {
  input a[8];
  input b[8];
  input c1[1];
  input c2[1];
  output q[8];
}

module M {
  reg r[8] = 0;
  if(c1) r := a;
  if(c2) r := b;
  q = r;
}

// CHECK-LABEL: hw.module @M
// CHECK: comb.mux
// CHECK: comb.mux
// CHECK: seq.firreg
// CHECK-NOT: nsl.
