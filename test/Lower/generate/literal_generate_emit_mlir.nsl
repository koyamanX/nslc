// SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
// RUN: %nslc -emit=mlir %s 2>/dev/null | %FileCheck %s
//
// M5 US2 / FR-014 ā€” end-to-end literal-bound generate fixture per
// the US2 acceptance scenario 1 (driven from pure NSL source).
//
// XFAIL CLOSED 2026-05-04 by the bundle:
//   - M4 amendment #5 (nsl.reg parent ā†’ StructuralGenerateOp)
//     [shipped in the M5 PR].
//   - FR-037 amendment (P3 severity downgrade) + lexer extension
//     folding `%i%` residue into surrounding identifier text.
//
// Pipeline: M1 IdentSplicer warns on `%i%` (loop-var residue) and
// leaves it verbatim ā†’ lexer tokenizes `buf_%i%` as a single
// identifier ā†’ ASTā†’MLIR visitor emits `nsl.reg "buf_%i%"` inside
// `nsl.structural_generate` ā†’ `NSLResolveParamsPass` (slot 1, no-op
// here ā€” no params) ā†’ `NSLExpandGeneratePass` (slot 2) clones the
// body 4 times with `%i%` substring substituted by the iteration
// index ā†’ `NSLCheckSemanticsPass` (slot 6) clears (no residue).

module GenLiteral {
    generate(i = 0; i < 4; i = i + 1) {
        reg buf_%i% = 0;
    }
}

// CHECK-LABEL: nsl.module @GenLiteral
// CHECK-NOT: nsl.structural_generate
// CHECK-DAG: nsl.reg "buf_0"
// CHECK-DAG: nsl.reg "buf_1"
// CHECK-DAG: nsl.reg "buf_2"
// CHECK-DAG: nsl.reg "buf_3"
