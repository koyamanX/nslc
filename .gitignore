#
# Build directories. The two-build determinism gate (Principle V)
# uses build1/build2; build-docker-smoke and any other build-* prefix
# are casual ad-hoc verification dirs.
build/
build1/
build2/
build-*/
out/

# lit's per-fixture output and timing cache (lit creates `Output/` at
# the test_source_root unless test_exec_root is set explicitly).
test/Output/
test/build*/

# Editor / OS detritus
*.bak
*.swp
*.tmp
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
.venv/
venv/

# lit
.lit_test_times.txt

# CMake user state
CMakeUserPresets.json
