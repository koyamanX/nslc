# SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
#
# .clang-tidy — LLVM/CIRCT-derived profile (FR-008).
#
# Stage 2 runs `clang-tidy -p build $(git ls-files '*.cpp')` against
# this profile. Reuses compile_commands.json from the stage-1
# Release × gcc cell.
#
# Determinism enforcement: the cert-msc51-cpp adjacent rules and
# explicit -Werror=date-time in NSLDeterminism.cmake together prevent
# __DATE__/__TIME__/__TIMESTAMP__ from leaking into build outputs
# (Principle V).

Checks: >
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  cppcoreguidelines-*,
  llvm-*,
  misc-*,
  modernize-*,
  performance-*,
  portability-*,
  readability-*,
  -bugprone-easily-swappable-parameters,
  -cppcoreguidelines-avoid-magic-numbers,
  -llvm-header-guard,
  -modernize-use-trailing-return-type,
  -readability-identifier-length,
  -readability-magic-numbers

WarningsAsErrors: ''

HeaderFilterRegex: '(include|lib|tools|test_unit)/.*\.(h|hpp)$'

# LLVM-style identifier-naming convention (subset of llvm-namespace-comment).
CheckOptions:
  - key: readability-identifier-naming.NamespaceCase
    value: lower_case
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  - key: readability-identifier-naming.FunctionCase
    value: camelBack
  - key: readability-identifier-naming.VariableCase
    value: camelBack
  - key: readability-identifier-naming.PrivateMemberSuffix
    value: ''
  - key: readability-identifier-naming.MacroDefinitionCase
    value: UPPER_CASE
