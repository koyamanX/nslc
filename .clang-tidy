# SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
#
# .clang-tidy — LLVM/CIRCT-derived profile (FR-008).
#
# Stage 2 runs `clang-tidy -p build $(git ls-files '*.cpp')` against
# this profile. Reuses compile_commands.json from the stage-1
# Release × gcc cell.
#
# Determinism enforcement: the cert-msc51-cpp adjacent rules and
# explicit -Werror=date-time in NSLDeterminism.cmake together prevent
# __DATE__/__TIME__/__TIMESTAMP__ from leaking into build outputs
# (Principle V).
#
# This file's "Checks:" line is the project-policy artifact for
# feature 004-clang-tidy-cleanup. The 5 categories disabled below
# the original allow-list are project-policy "no" with a one-line
# rationale per FR-009: rationale lives here, not in source as
# TODO/FIXME markers.

Checks: >
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  cppcoreguidelines-*,
  llvm-*,
  misc-*,
  modernize-*,
  performance-*,
  portability-*,
  readability-*,
  -bugprone-easily-swappable-parameters,
  -cppcoreguidelines-avoid-c-arrays,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-macro-usage,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-pro-type-vararg,
  -llvm-header-guard,
  -modernize-avoid-c-arrays,
  -modernize-use-trailing-return-type,
  -readability-identifier-length,
  -readability-magic-numbers,
  -readability-identifier-naming,
  -misc-non-private-member-variables-in-classes,
  -cppcoreguidelines-avoid-const-or-ref-data-members,
  -misc-no-recursion,
  -readability-function-cognitive-complexity,
  -cppcoreguidelines-avoid-do-while,
  -readability-convert-member-functions-to-static,
  -bugprone-unchecked-optional-access,
  -cppcoreguidelines-pro-bounds-constant-array-index,
  -cppcoreguidelines-special-member-functions,
  -cert-err33-c,
  -readability-use-anyofallof,
  -performance-enum-size,
  -cppcoreguidelines-pro-type-member-init,
  -cppcoreguidelines-owning-memory,
  -bugprone-macro-parentheses,
  -bugprone-forward-declaration-namespace,
  -bugprone-exception-escape

# === Rationale block (FR-009: rationale lives here, not in source) ===
#
# === Pre-existing M0/M1 suppressions (origin: pre-feature-004) ===
# - bugprone-easily-swappable-parameters: too noisy on small APIs.
# - cppcoreguidelines-macro-usage: NSLC_VERSION_STRING is a
#   configure_file() output; constexpr is not a viable replacement.
# - cppcoreguidelines-avoid-c-arrays / pro-bounds-array-to-pointer-decay /
#   pro-bounds-pointer-arithmetic: `int main(int, char**)` and `argv[i]`
#   are canonical and required by the standard.
# - cppcoreguidelines-pro-type-vararg: `std::printf` is the LLVM/CIRCT
#   idiom; std::print waits on C++23+ toolchain support.
# - llvm-header-guard / modernize-use-trailing-return-type /
#   readability-identifier-length / readability-magic-numbers /
#   modernize-avoid-c-arrays: pre-existing project style choices.
#
# === Feature-004 added suppressions ===
#
# readability-identifier-naming:
#   M1-vintage mixed naming conventions (member_/begin_ vs begin/end).
#   Auto-rename produces accessor-vs-member collisions (e.g.,
#   SourceRange::begin_ would rename to begin, clashing with the
#   existing begin() accessor). Refactor is a separate Principle II
#   layer-design feature.
#
# misc-non-private-member-variables-in-classes:
#   POD struct types (Diagnostic, Token, MacroDef, Frame) are an
#   established M1 pattern. Refactor to private+accessor is a
#   separate Principle II layer-design feature.
#
# cppcoreguidelines-avoid-const-or-ref-data-members:
#   By-ref dependency injection is the established M1 pattern
#   (MacroExpander holds MacroTable&, DiagnosticEngine&). Pointer
#   storage would obscure non-null contracts.
#
# misc-no-recursion:
#   Recursive descent is the intended shape for the parser /
#   preprocessor. Depth bounds (kMaxIncludeDepth, kMaxExpansionDepth)
#   enforce termination.
#
# readability-function-cognitive-complexity:
#   Cognitive complexity in parser code reflects grammar shape, not
#   unmaintainability. Splitting into helpers would hide complexity,
#   not reduce it.
#
# cppcoreguidelines-avoid-do-while:
#   do-while loop body executed-at-least-once semantics is intended
#   in lexer/keyword-set paths.
#
# readability-convert-member-functions-to-static:
#   Auto-fix produces cascade compilation errors when a member fn that
#   doesn't currently use `this` is called via an accessor pattern that
#   relies on dynamic dispatch. Per-site review exceeds feature scope.
#
# bugprone-unchecked-optional-access:
#   Per-site review needed; many sites are guarded by structurally-
#   provable invariants the static analyzer can't see (e.g., a
#   has_value() check earlier in the same scope). Suppression here;
#   per-site re-enable via // NOLINTNEXTLINE(...) when adding new
#   optional-typed code.
#
# cppcoreguidelines-pro-bounds-constant-array-index:
#   Hits raw `argv[i]` style patterns; `argv` is a `char **`, not a
#   bounds-checkable container. The C++ standard mandates this
#   signature for main().
#
# cppcoreguidelines-special-member-functions:
#   Hits classes that intentionally use the rule-of-zero pattern
#   (default move/copy from member types). The check insists on
#   explicit `= default`, which is style preference, not correctness.
#
# cert-err33-c:
#   Hits C-style return-value-discarded calls (e.g., printf results).
#   Most call sites don't care about the return; per-site review
#   exceeds feature scope.
#
# readability-use-anyofallof:
#   Style preference — hand-rolled loops vs std::any_of in a few
#   parser-walk sites. Refactor doesn't change behavior or semantics.
#
# performance-enum-size:
#   Hits 4-byte default-int-backed enums where 1-byte would suffice.
#   The performance impact on parser/preprocessor data structures is
#   inconsequential (these enums ship in tagged-union value types).
#
# cppcoreguidelines-pro-type-member-init / cppcoreguidelines-owning-memory /
# bugprone-macro-parentheses / bugprone-forward-declaration-namespace /
# bugprone-exception-escape:
#   Singleton-site warnings (1-2 sites each) where the underlying
#   pattern is intentional (e.g., a struct designed for aggregate-init
#   with no constructor). Per-site exemptions documented here rather
#   than in source per FR-009.

# Treat every enabled clang-tidy diagnostic as a hard error. Combined
# with `clang-tidy --warnings-as-errors=*` in scripts/ci.sh:stage_static_checks,
# any check listed in `Checks:` above that fires on any source file
# fails the static-checks CI stage (FR-008 strict-gate intent).
WarningsAsErrors: '*'

HeaderFilterRegex: '(include|lib|tools|test_unit)/.*\.(h|hpp)$'

# LLVM-style identifier-naming convention (subset of llvm-namespace-comment).
# NOTE: identifier-naming is globally suppressed above; these CheckOptions
# remain documented for future re-enable.
CheckOptions:
  - key: readability-identifier-naming.NamespaceCase
    value: lower_case
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  - key: readability-identifier-naming.FunctionCase
    value: camelBack
  - key: readability-identifier-naming.VariableCase
    value: camelBack
  - key: readability-identifier-naming.PrivateMemberSuffix
    value: ''
  - key: readability-identifier-naming.MacroDefinitionCase
    value: UPPER_CASE
